<!-- Core-platform variant of the bookmark backend registration, for IDEs (2026.1 and earlier)
     where com.intellij.ide.bookmark.* is part of the monolith core rather than the separate
     intellij.platform.bookmarks plugin module. Unlike IdeaVIM.ideavim-backend-bookmarks, it does
     NOT depend on intellij.platform.bookmarks, so it stays enabled on those older IDEs.

     Both variants share the same BookmarkRemoteApiProvider source; that provider registers only
     when the bookmark classes are resolvable from its own classloader, so on any given IDE exactly
     one of the two variants activates (module-backed on 2026.2+, core-backed here on <=2026.1). -->
<idea-plugin>
  <dependencies>
    <module name="intellij.platform.backend"/>
    <module name="intellij.platform.kernel.backend"/>
    <module name="IdeaVIM.ideavim-common"/>
  </dependencies>

  <extensions defaultExtensionNs="com.intellij">
    <!-- RPC: expose bookmark creation to thin-client frontend -->
    <platform.rpc.backend.remoteApiProvider
        implementation="com.maddyhome.idea.vim.group.bookmark.BookmarkRemoteApiProvider"/>
  </extensions>
</idea-plugin>
