<idea-plugin>
  <dependencies>
    <module name="intellij.platform.backend"/>
    <module name="intellij.platform.kernel.backend"/>
    <module name="IdeaVIM.ideavim-common"/>
  </dependencies>

  <!-- Backend registrations: IdeDocumentHistory, Bookmarks, ProjectView, PSI.
       These load in backend + monolith mode only. -->

  <projectListeners>
    <listener class="com.maddyhome.idea.vim.group.jump.JumpsListener"
              topic="com.intellij.openapi.fileEditor.impl.IdeDocumentHistoryImpl$RecentPlacesListener"/>
  </projectListeners>

  <extensions defaultExtensionNs="com.intellij">
    <!-- Backend services — run in backend + monolith mode -->
    <applicationService serviceImplementation="com.maddyhome.idea.vim.group.process.ProcessGroup"
                        serviceInterface="com.maddyhome.idea.vim.api.VimProcessGroup"/>

    <!-- Backend-only jump storage for JumpsListener (not a VimJumpService).
         In split mode, JumpsListener writes here; frontend reads via JumpRemoteApi.
         In monolith mode, JumpsListener writes directly to VimJumpServiceImpl instead. -->
    <applicationService serviceImplementation="com.maddyhome.idea.vim.group.jump.BackendJumpStorage"/>

    <applicationService serviceImplementation="com.maddyhome.idea.vim.group.file.FileBackendServiceImpl"
                        serviceInterface="com.maddyhome.idea.vim.group.file.FileBackendService"/>

    <applicationService serviceImplementation="com.maddyhome.idea.vim.group.bookmark.BookmarkBackendServiceImpl"
                        serviceInterface="com.maddyhome.idea.vim.group.bookmark.BookmarkBackendService"/>

    <!-- RPC: expose ProcessGroup to thin-client frontend -->
    <platform.rpc.backend.remoteApiProvider
        implementation="com.maddyhome.idea.vim.group.process.ProcessRemoteApiProvider"/>

    <!-- RPC: expose includeCurrentCommandAsNavigation to thin-client frontend -->
    <platform.rpc.backend.remoteApiProvider
        implementation="com.maddyhome.idea.vim.group.jump.JumpRemoteApiProvider"/>

    <!-- RPC: expose file operations to thin-client frontend -->
    <platform.rpc.backend.remoteApiProvider
        implementation="com.maddyhome.idea.vim.group.file.FileRemoteApiProvider"/>

    <!-- RPC: expose bookmark creation to thin-client frontend -->
    <platform.rpc.backend.remoteApiProvider
        implementation="com.maddyhome.idea.vim.group.bookmark.BookmarkRemoteApiProvider"/>

  </extensions>
</idea-plugin>
