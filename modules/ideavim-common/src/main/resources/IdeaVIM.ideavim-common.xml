<idea-plugin>
  <!-- Shared code and extension points loaded in ALL product modes (monolith, client, backend).
       Extension point declarations must be here so both frontend and backend can contribute to them. -->

  <applicationListeners>
    <listener class="com.maddyhome.idea.vim.thinapi.IjPluginListener"
              topic="com.intellij.ide.plugins.DynamicPluginListener"/>
  </applicationListeners>

  <extensionPoints>
    <extensionPoint name="vimExtension" beanClass="com.maddyhome.idea.vim.extension.ExtensionBeanClass" dynamic="true">
      <with attribute="implementation" implements="com.maddyhome.idea.vim.extension.VimExtension"/>

    </extensionPoint>
    <extensionPoint interface="com.maddyhome.idea.vim.ide.ClionNovaProvider" dynamic="true" name="clionNovaProvider"/>
    <extensionPoint interface="com.maddyhome.idea.vim.ide.RiderProvider" dynamic="true" name="riderProvider"/>
    <extensionPoint interface="com.maddyhome.idea.vim.key.IdeaVimDisablerExtensionPoint" dynamic="true"
                    name="internal.disabler"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <!-- Main plugin service (persistent state, initialisation) — used from common code (VimPlugin.isEnabled()) -->
    <applicationService serviceImplementation="com.maddyhome.idea.vim.VimPlugin"/>

    <!-- Services that must be available in ALL product modes (used by both frontend and backend).
         Frontend-only services are registered in ideavim-frontend.xml.
         Backend-only services are registered in ideavim-backend.xml. -->
    <applicationService serviceImplementation="com.maddyhome.idea.vim.group.VimJumpServiceSplitClient"
                        serviceInterface="com.maddyhome.idea.vim.api.VimJumpService"/>
    <applicationService serviceImplementation="com.maddyhome.idea.vim.group.RegisterGroup"
                        serviceInterface="com.maddyhome.idea.vim.register.VimRegisterGroup"/>
    <applicationService serviceImplementation="com.maddyhome.idea.vim.newapi.IjVimSearchGroup"/>
    <applicationService serviceImplementation="com.maddyhome.idea.vim.group.HistoryGroup"/>

    <applicationService serviceImplementation="com.maddyhome.idea.vim.group.OptionGroup"
                        serviceInterface="com.maddyhome.idea.vim.api.VimOptionGroup"/>
    <!-- Transitive dependencies of OptionGroup (accessed during construction via VimOptionGroupBase) -->
    <applicationService serviceImplementation="com.maddyhome.idea.vim.group.IjVimStorageService"
                        serviceInterface="com.maddyhome.idea.vim.api.VimStorageService"/>
    <applicationService serviceImplementation="com.maddyhome.idea.vim.group.IjVimSystemInfoService"
                        serviceInterface="com.maddyhome.idea.vim.api.SystemInfoService"/>
    <applicationService serviceImplementation="com.maddyhome.idea.vim.group.IjVimRedrawService"
                        serviceInterface="com.maddyhome.idea.vim.api.VimRedrawService"/>

    <!-- Platform-managed coroutine scope for split-mode RPC clients -->
    <applicationService serviceImplementation="com.maddyhome.idea.vim.group.CoroutineScopeProvider"/>

  </extensions>


</idea-plugin>
