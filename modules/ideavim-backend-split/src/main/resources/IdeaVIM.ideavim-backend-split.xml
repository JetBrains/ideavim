<idea-plugin>
  <dependencies>
    <module name="intellij.platform.backend.split"/>
    <module name="IdeaVIM.ideavim-common"/>
  </dependencies>

  <!-- No-op services for split-backend mode (no editors on backend). -->
  <extensions defaultExtensionNs="com.intellij">
    <applicationService serviceImplementation="com.maddyhome.idea.vim.group.BackendEditorGroup"
                        serviceInterface="com.maddyhome.idea.vim.api.VimEditorGroup"/>
    <applicationService serviceImplementation="com.maddyhome.idea.vim.group.BackendKeyGroup"
                        serviceInterface="com.maddyhome.idea.vim.api.VimKeyGroup"/>
  </extensions>
</idea-plugin>
